# Copy to server/.env and fill in. server/.env is gitignored — never commit your token.
# Compose auto-loads this file for the GITHUB_USER/GITHUB_TOKEN interpolations.
# Leave empty to keep GitHub presence "idle".
GITHUB_USER=your-github-username
# A classic or fine-grained PAT; read-only (public events / read:user) is enough.
GITHUB_TOKEN=ghp_your_token_here
# Google Calendar private iCal "secret address" (read-only). Empty -> calendar presence off.
# Settings -> your calendar -> "Secret address in iCal format". Keep this file gitignored.
CALENDAR_ICS_URL=
